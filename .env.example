# PostgreSQL (Neon recomendado — local e Vercel)
# Opção rápida: npx vercel env pull .env.local  (usa o mesmo banco da produção)
# Ou cole a connection string do Neon:
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

JWT_SECRET="change-me-to-a-long-random-string-min-32-chars"
OPENAI_API_KEY="sk-..."

# Seed (primeira vez: npm run db:push && npm run db:seed)
ADMIN_EMAIL="admin@sistema.local"
ADMIN_PASSWORD="rmbvadmin"
ADMIN_NAME="Admin"
ADV_EMAIL="adv@sistema.local"
ADV_PASSWORD="Adv@123"
ADV_NAME="ADV"
GERENTE_EMAIL="gerente@sistema.local"
GERENTE_PASSWORD="Gerente@123"
GERENTE_NAME="Gerente"

# Vercel Blob — Storage no painel Vercel → Storage → Blob (produção)
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
