datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum WorkType {
  ESTAGIARIO
  CLT
}

enum PontoOrigin {
  MOBILE
  KIOSK
  DESKTOP
}

enum FaceAuditAction {
  CONSENT_ACCEPT
  ENROLL
  RE_ENROLL
  DELETE
  PONTO_OK
  PONTO_FAIL
}

enum Role {
  ADMIN
  ADV
  GERENTE
  TI
  COLABORADOR
  PESQUISADOR
}

enum ClientWorkflowStatus {
  EM_ANDAMENTO
  FINALIZACAO_SOLICITADA
  FINALIZADO
}

enum ClientStatus {
  AGUARDANDO
  LOCALIZADO
  SEM_SUCESSO
  TENTE_NOVAMENTE
}

enum ClientHistoryType {
  STATUS_CHANGE
  PHONE_CHECK
  CALL
  WHATSAPP
  NOTE
  PESQUISA_UPDATED
}

enum PhoneCheckResult {
  VALIDO
  INVALIDO
  NAO_ATENDE
}

enum TaskHistoryType {
  CREATED
  COMMENT
  COLUMN_CHANGE
  FIELD_UPDATE
}

enum TaskPriority {
  BAIXA
  MEDIA
  ALTA
}

enum ChamadoStatus {
  ABERTO
  EM_ANDAMENTO
  AGUARDANDO_VALIDACAO
  AG_FECHAMENTO
  FECHADO
}

enum ChamadoCategory {
  BUG
  SUGESTOES
  SOLICITACOES
}

enum ChamadoHistoryType {
  CREATED
  STATUS_CHANGE
  ASSIGNEE_CHANGE
  COMMENT
  FIELD_UPDATE
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ownerId   String?
  owner     User?    @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  members   User[]   @relation("TeamMembers")
  clients   Client[]
  teses     Tese[]
  tasks     Task[]
  kanbanColumns KanbanColumn[]
  messageTemplates MessageTemplate[]
  goals     TeamGoal[]
  taskLabels TaskLabel[]
  chamados  Chamado[]
  automationRules AutomationRule[]
  documentTemplates DocumentTemplate[]
  chamadoSlaConfigs ChamadoSlaConfig[]
  accessRules       UserAccessRule[]
  pontoRecords      PontoRecord[]
  chatMessages      ChatMessage[]
  acoes             Acao[]
  scheduleEnabled   Boolean  @default(true)
  scheduleDays      String   @default("[1,2,3,4,5]")
  scheduleStart     Int      @default(8)
  scheduleEnd       Int      @default(19)
  /// ADV pode liberar para o Gerente cadastrar rostos da equipe
  allowGerenteFaceEnrollment Boolean @default(false)
  officeLatitude             Float?
  officeLongitude            Float?
  defaultGpsRadiusMeters     Int      @default(200)
}

model TeseChecklistItem {
  id        String   @id @default(uuid())
  teseId    String
  tese      Tese     @relation(fields: [teseId], references: [id], onDelete: Cascade)
  label     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  progress  ClientChecklistProgress[]

  @@index([teseId, sortOrder])
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  passwordHash   String
  role           Role     @default(COLABORADOR)
  teamId         String?
  team           Team?    @relation("TeamMembers", fields: [teamId], references: [id], onDelete: Restrict)
  isActive       Boolean  @default(true)
  faceDescriptor Json?
  avatarUrl      String?
  mustChangePassword Boolean @default(true)
  workType       WorkType @default(CLT)
  lgpdFaceConsentAt DateTime?
  lgpdFaceConsentVersion String?
  gpsRequired    Boolean  @default(false)
  gpsRadiusMeters Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ownedTeams     Team[]   @relation("TeamOwner")
  clientsCreated              Client[]           @relation("CreatedBy")
  documentsUploaded           ClientDocument[]   @relation("DocumentsUploaded")
  finalizationRequests        Client[]           @relation("FinalizationRequested")
  finalizationApprovals       Client[]           @relation("FinalizationApproved")
  clientHistory               ClientHistory[]    @relation("HistoryAuthor")
  tasksAssigned               Task[]             @relation("TaskAssignee")
  tasksCreated                Task[]             @relation("TaskCreator")
  taskHistory                 TaskHistory[]      @relation("TaskHistoryAuthor")
  messageTemplates            MessageTemplate[]  @relation("TemplateAuthor")
  teamGoals                   TeamGoal[]         @relation("GoalAssignee")
  checklistMarked             ClientChecklistProgress[] @relation("ChecklistDoneBy")
  chamadosRequested           Chamado[]          @relation("ChamadoRequester")
  chamadosAssigned            Chamado[]          @relation("ChamadoAssignee")
  chamadoComments             ChamadoComment[]
  chamadoAttachments          ChamadoAttachment[] @relation("ChamadoAttachmentUploader")
  chamadoHistory              ChamadoHistory[]   @relation("ChamadoHistoryAuthor")
  notifications               Notification[]
  auditLogs                   AuditLog[]         @relation("AuditLogUser")
  onboarding                  UserOnboarding?
  sessions                    UserSession[]
  accessRule                  UserAccessRule?
  pontoRecords                PontoRecord[]
  chatMessagesSent            ChatMessage[]      @relation("ChatSender")
  chatMessagesReceived        ChatMessage[]      @relation("ChatReceiver")
  faceAuditsAsActor           FaceAuditLog[]     @relation("FaceAuditActor")
  faceAuditsAsTarget          FaceAuditLog[]     @relation("FaceAuditTarget")
  acoesCreated                Acao[]             @relation("AcaoCreator")
  acoesAdvConfirmado          Acao[]             @relation("AcaoAdvConfirmado")
  acoesDocsEnviados           Acao[]             @relation("AcaoDocsEnviados")
  acoesEntrada                Acao[]             @relation("AcaoEntrada")
  acoesSentenca               Acao[]             @relation("AcaoSentenca")
  supportRequests             SupportRequest[]
  assignedTickets             SupportRequest[]    @relation("AssignedTickets")
  ticketResponses             SupportTicketResponse[]

  @@index([teamId])
}

enum PontoType {
  ENTRADA
  SAIDA
  INTERVALO_INICIO
  INTERVALO_FIM
}

model PontoRecord {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId     String?
  team       Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  type       PontoType
  origin     PontoOrigin?
  latitude   Float?
  longitude  Float?
  confidence Float?
  recordedAt DateTime  @default(now())

  @@index([userId])
  @@index([teamId])
  @@index([recordedAt])
}

model FaceAuditLog {
  id           String          @id @default(uuid())
  actorId      String
  actor        User            @relation("FaceAuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUserId String?
  targetUser   User?           @relation("FaceAuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  teamId       String?
  action       FaceAuditAction
  metadata     Json?
  createdAt    DateTime        @default(now())

  @@index([teamId, createdAt])
  @@index([targetUserId, createdAt])
  @@index([createdAt])
}

model Tese {
  id        String   @id @default(uuid())
  name      String
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  color     String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  clients   Client[]
  checklistItems TeseChecklistItem[]

  @@unique([teamId, name])
  @@index([teamId])
}

model Category {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions Permission[]
  clients     ClientCategory[]
}

model Permission {
  id         String   @id @default(uuid())
  role       Role
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  canCreate  Boolean  @default(false)
  canRead    Boolean  @default(false)
  canUpdate  Boolean  @default(false)
  canDelete  Boolean  @default(false)

  @@unique([role, categoryId])
}

model Client {
  id             String           @id @default(uuid())
  cod            String?
  teseId         String?
  teseRef        Tese?            @relation(fields: [teseId], references: [id], onDelete: SetNull)
  tese           String?
  name           String
  cpf            String?
  birthDate      String?
  obito          String?
  deathDate      String?
  phone1         String?
  phone2         String?
  phone3         String?
  phone4         String?
  phone5         String?
  phone6         String?
  phone7         String?
  phone8         String?
  phone9         String?
  phone10        String?
  address1       String?
  address2       String?
  address3       String?
  status                    ClientStatus           @default(AGUARDANDO)
  workflowStatus            ClientWorkflowStatus   @default(EM_ANDAMENTO)
  finalizationRequestedAt   DateTime?
  finalizationRequestedById String?
  finalizationRequestedBy   User?                  @relation("FinalizationRequested", fields: [finalizationRequestedById], references: [id])
  finalizedAt               DateTime?
  finalizedById             String?
  finalizedBy               User?                  @relation("FinalizationApproved", fields: [finalizedById], references: [id])
  pesquisa                  String?                @map("rawExtractText")
  createdAt                 DateTime               @default(now())
  updatedAt      DateTime         @updatedAt
  teamId         String?
  team           Team?            @relation(fields: [teamId], references: [id], onDelete: Restrict)
  createdById    String
  createdBy      User             @relation("CreatedBy", fields: [createdById], references: [id])
  categories     ClientCategory[]
  documents      ClientDocument[]
  history        ClientHistory[]
  tasks          Task[]
  checklistProgress ClientChecklistProgress[]
  chamados          Chamado[]
  relatives         ClientRelative[]
  acoes             Acao[]

  // Endereço estruturado (para cartas)
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  uf           String?

  // Retorno agendado — denormalizado do último histórico com followUpAt
  followUpAt   DateTime?

  @@index([teamId])
  @@index([teamId, status])
  @@index([teamId, workflowStatus])
  @@index([teseId])
  @@index([followUpAt])
}

model ClientRelative {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name         String
  relationship String
  phone1       String?
  phone2       String?
  phone3       String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
}

model ClientChecklistProgress {
  id        String   @id @default(uuid())
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  itemId    String
  item      TeseChecklistItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  isDone    Boolean  @default(false)
  doneAt    DateTime?
  doneById  String?
  doneBy    User?    @relation("ChecklistDoneBy", fields: [doneById], references: [id], onDelete: SetNull)
  updatedAt DateTime @updatedAt

  @@unique([clientId, itemId])
  @@index([clientId])
}

model ClientHistory {
  id            String             @id @default(uuid())
  clientId      String
  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  type          ClientHistoryType
  createdAt     DateTime           @default(now())
  createdById   String
  createdBy     User               @relation("HistoryAuthor", fields: [createdById], references: [id])
  fromStatus    ClientStatus?
  toStatus      ClientStatus?
  note          String?
  phoneKey      String?
  phoneNumber   String?
  phoneCheck    PhoneCheckResult?

  @@index([clientId, createdAt])
}

model MessageTemplate {
  id          String   @id @default(uuid())
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name        String
  body        String
  createdById String
  createdBy   User     @relation("TemplateAuthor", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId, name])
}

model TeamGoal {
  id                  String   @id @default(uuid())
  teamId              String
  team                Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  assigneeId          String?
  assignee            User?    @relation("GoalAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  monthKey            String
  targetFinalizations Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([teamId, monthKey, assigneeId])
  @@index([teamId, monthKey])
}

model ClientDocument {
  id           String   @id @default(uuid())
  clientId     String
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  storedName   String
  originalName String
  mimeType     String
  size         Int
  tags         String   @default("[]")
  uploadedById String
  uploadedBy   User     @relation("DocumentsUploaded", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([clientId])
}

model ClientCategory {
  clientId   String
  categoryId String
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([clientId, categoryId])
}

model Task {
  id          String        @id @default(uuid())
  title       String
  description String?
  priority    TaskPriority  @default(MEDIA)
  columnId    String
  column      KanbanColumn  @relation(fields: [columnId], references: [id], onDelete: Restrict)
  dueAt       DateTime?
  sortOrder   Int           @default(0)
  teamId      String
  team        Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  clientId    String?
  client      Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  assigneeId  String?
  assignee    User?         @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  chamadoId   String?       @unique
  chamado     Chamado?      @relation(fields: [chamadoId], references: [id], onDelete: SetNull)
  createdById String
  createdBy   User          @relation("TaskCreator", fields: [createdById], references: [id])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  history     TaskHistory[]
  labels      TaskLabelOnTask[]

  @@index([teamId, columnId, sortOrder])
  @@index([assigneeId])
  @@index([clientId])
  @@index([priority])
}

model TaskLabel {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  color     String   @default("#0f766e")
  createdAt DateTime @default(now())
  tasks     TaskLabelOnTask[]

  @@unique([teamId, name])
  @@index([teamId])
}

model TaskLabelOnTask {
  taskId  String
  labelId String
  task    Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label   TaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([taskId, labelId])
}

model Chamado {
  id            String          @id @default(uuid())
  number        Int
  title         String
  description   String?
  status        ChamadoStatus   @default(ABERTO)
  priority      TaskPriority    @default(MEDIA)
  category      ChamadoCategory
  teamId        String
  team          Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
  requesterId   String
  requester     User            @relation("ChamadoRequester", fields: [requesterId], references: [id])
  assigneeId    String?
  assignee      User?           @relation("ChamadoAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  clientId      String?
  client        Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  statusChangedAt DateTime      @default(now())
  slaDueAt        DateTime?
  comments      ChamadoComment[]
  attachments   ChamadoAttachment[]
  history       ChamadoHistory[]
  linkedTask    Task?

  @@unique([teamId, number])
  @@index([teamId, status])
  @@index([requesterId])
  @@index([assigneeId])
}

model ChamadoComment {
  id          String   @id @default(uuid())
  chamadoId   String
  chamado     Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  authorId    String
  author      User     @relation(fields: [authorId], references: [id])
  body        String
  createdAt   DateTime @default(now())

  @@index([chamadoId, createdAt])
}

model ChamadoAttachment {
  id           String   @id @default(uuid())
  chamadoId    String
  chamado      Chamado  @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  storedName   String
  originalName String
  mimeType     String
  size         Int
  uploadedById String
  uploadedBy   User     @relation("ChamadoAttachmentUploader", fields: [uploadedById], references: [id])
  createdAt    DateTime @default(now())

  @@index([chamadoId])
}

model ChamadoHistory {
  id          String             @id @default(uuid())
  chamadoId   String
  chamado     Chamado            @relation(fields: [chamadoId], references: [id], onDelete: Cascade)
  type        ChamadoHistoryType
  note        String?
  fromLabel   String?
  toLabel     String?
  createdAt   DateTime           @default(now())
  createdById String
  createdBy   User               @relation("ChamadoHistoryAuthor", fields: [createdById], references: [id])

  @@index([chamadoId, createdAt])
}

model KanbanColumn {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  sortOrder Int      @default(0)
  color     String?
  isDone    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[]

  @@unique([teamId, name])
  @@index([teamId, sortOrder])
}

model TaskHistory {
  id          String          @id @default(uuid())
  taskId      String
  task        Task            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        TaskHistoryType
  note        String?
  fromLabel   String?
  toLabel     String?
  createdAt   DateTime        @default(now())
  createdById String
  createdBy   User            @relation("TaskHistoryAuthor", fields: [createdById], references: [id])

  @@index([taskId, createdAt])
}

enum NotificationType {
  TASK_OVERDUE
  TASK_ASSIGNED
  CHAMADO_ASSIGNED
  CHAMADO_SLA
  CLIENT_FINALIZATION
  CLIENT_DOCUMENT
  PROCESSUAL_UPDATE
  GENERAL
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  STATUS_CHANGE
}

enum AutomationTrigger {
  CLIENT_STATUS_LOCALIZADO
  CLIENT_WORKFLOW_FINALIZACAO
  DOCUMENT_UPLOADED
  CHAMADO_CREATED
}

enum AutomationAction {
  CREATE_TASK
  NOTIFY_ASSIGNEE
  NOTIFY_TEAM
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String?
  href      String?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, read, createdAt])
}

model AuditLog {
  id        String      @id @default(uuid())
  userId    String?
  user      User?       @relation("AuditLogUser", fields: [userId], references: [id], onDelete: SetNull)
  action    AuditAction
  entity    String
  entityId  String?
  summary   String
  metadata  Json?
  createdAt DateTime    @default(now())

  @@index([createdAt])
  @@index([entity, entityId])
}

model AutomationRule {
  id        String            @id @default(uuid())
  teamId    String
  team      Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  enabled   Boolean           @default(true)
  trigger   AutomationTrigger
  action    AutomationAction
  config    Json?
  createdAt DateTime          @default(now())

  @@index([teamId, enabled])
}

model DocumentTemplate {
  id        String   @id @default(uuid())
  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  name      String
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, name])
  @@index([teamId])
}

model ChamadoSlaConfig {
  id     String        @id @default(uuid())
  teamId String
  team   Team          @relation(fields: [teamId], references: [id], onDelete: Cascade)
  status ChamadoStatus
  hours  Int

  @@unique([teamId, status])
}

model UserOnboarding {
  userId          String   @id
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  completedSteps  Json     @default("[]")
  dismissed       Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model UserSession {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  ipAddress   String?
  userAgent   String?
  loginAt     DateTime @default(now())

  @@index([userId, loginAt])
}

model UserAccessRule {
  id          String   @id @default(uuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  teamId      String
  team        Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  allowedDays String   @default("[1,2,3,4,5]")
  startHour   Int      @default(8)
  endHour     Int      @default(18)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([teamId])
}

model ChatMessage {
  id         String    @id @default(cuid())
  teamId     String
  team       Team      @relation(fields: [teamId], references: [id], onDelete: Cascade)
  senderId   String
  sender     User      @relation("ChatSender", fields: [senderId], references: [id])
  receiverId String?
  receiver   User?     @relation("ChatReceiver", fields: [receiverId], references: [id])
  body       String    @db.Text
  createdAt  DateTime  @default(now())

  @@index([teamId, receiverId, createdAt])
  @@index([senderId])
}

model Acao {
  id          String   @id @default(uuid())
  clientId    String
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  teamId      String?
  team        Team?    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  numCNJ      String?
  numProcesso String?                        @unique
  valorCausa  Float?
  createdById String
  createdBy   User     @relation("AcaoCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  advConfirmadoAt   DateTime?
  advConfirmadoById String?
  advConfirmadoBy   User?     @relation("AcaoAdvConfirmado", fields: [advConfirmadoById], references: [id], onDelete: SetNull)
  advNota           String?

  docsEnviadosAt    DateTime?
  docsEnviadosById  String?
  docsEnviadosBy    User?     @relation("AcaoDocsEnviados", fields: [docsEnviadosById], references: [id], onDelete: SetNull)
  docsNota          String?

  entradaAt         DateTime?
  entradaById       String?
  entradaBy         User?     @relation("AcaoEntrada", fields: [entradaById], references: [id], onDelete: SetNull)
  entradaNota       String?

  sentencaAt        DateTime?
  sentencaById      String?
  sentencaBy        User?     @relation("AcaoSentenca", fields: [sentencaById], references: [id], onDelete: SetNull)
  sentencaResultado String?
  sentencaNota      String?

  // Acompanhamento processual
  classe             String?
  assunto            String?
  vara               String?
  foro               String?
  tribunal           String?
  sistema            String?                    @default("DATAJUD")
  ultimaMovimentacaoAt   DateTime?
  ultimaMovimentacaoText String?
  dataAjuizamento    DateTime?
  dataDistribuicao   DateTime?
  valorAtualizado    Float?
  parteContraria     String?
  ultimaConsultaAt   DateTime?
  consultaStatus     String?                    @default("pendente")

  movimentacoes Movimentacao[]

  @@index([clientId])
  @@index([teamId])
  @@index([numProcesso])
}

model Movimentacao {
  id        String   @id @default(uuid())
  acaoId    String
  acao      Acao     @relation(fields: [acaoId], references: [id], onDelete: Cascade)
  data      DateTime
  texto     String   @db.Text
  tipo      String?
  hash      String   @unique
  createdAt DateTime @default(now())

  @@index([acaoId])
  @@index([data])
}

enum TicketStatus {
  ABERTO
  EM_ANDAMENTO
  RESOLVIDO
  FECHADO
}

model SupportRequest {
  id           String             @id @default(uuid())
  name         String
  sala         String
  necessidade  String
  outroTexto   String?
  obs          String?
  email        String?
  requesterId  String?
  requester    User?              @relation(fields: [requesterId], references: [id])
  status       TicketStatus       @default(ABERTO)
  assignedToId String?
  assignedTo   User?              @relation("AssignedTickets", fields: [assignedToId], references: [id])
  responses    SupportTicketResponse[]
  createdAt    DateTime           @default(now())

  @@index([requesterId])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([status])
}

model SupportTicketResponse {
  id        String         @id @default(uuid())
  ticketId  String
  ticket    SupportRequest @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id])
  message   String
  createdAt DateTime       @default(now())

  @@index([ticketId])
  @@index([userId])
}
