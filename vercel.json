{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma migrate deploy && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/purge-retention",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sla-alerts",
      "schedule": "0 8 * * *"
    }
  ]
}
