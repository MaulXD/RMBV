{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma generate && prisma db push --accept-data-loss && next build",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/purge-retention",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/sla-alerts",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/processual-update",
      "schedule": "0 6 * * *"
    }
  ]
}
